# DeepSeek Trading Bot — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# DeepSeek V4 Pro API
DEEPSEEK_API_KEY=

# Signum OAuth (obtained by running setup_oauth.py ONCE)
SIGNUM_CLIENT_ID=
SIGNUM_REFRESH_TOKEN=

# Telegram notifications (optional — bot will skip if unset)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

